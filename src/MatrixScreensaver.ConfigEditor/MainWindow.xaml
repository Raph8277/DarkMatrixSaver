<Window x:Class="MatrixScreensaver.ConfigEditor.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Matrix Screensaver Config Editor" Width="1260" Height="860" Background="#111">
    <Window.Resources>
        <Style TargetType="{x:Type TextBlock}">
            <Setter Property="Foreground" Value="#D8D8D8" />
        </Style>
        <Style TargetType="{x:Type GroupBox}">
            <Setter Property="Foreground" Value="#E6E6E6" />
        </Style>
        <Style TargetType="{x:Type CheckBox}">
            <Setter Property="Foreground" Value="#D8D8D8" />
        </Style>
        <Style TargetType="{x:Type TextBox}">
            <Setter Property="Foreground" Value="#111111" />
            <Setter Property="Background" Value="#F2F2F2" />
            <Setter Property="BorderBrush" Value="#6A6A6A" />
        </Style>
    </Window.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
            <Button Content="Ouvrir JSON" Click="Open_Click" Padding="14,8" Margin="0,0,8,0" />
            <Button Content="Sauvegarder" Click="Save_Click" Padding="14,8" Margin="0,0,8,0" />
            <Button Content="Preset Defaut (DemonBar)" Click="Demon_Click" Padding="14,8" Margin="0,0,8,0" />
            <Button Content="Formulaire -> JSON" Click="ApplyFormToJson_Click" Padding="14,8" Margin="0,0,8,0" />
            <Button Content="JSON -> Formulaire" Click="ApplyJsonToForm_Click" Padding="14,8" />
        </StackPanel>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="500" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="#1A1A1A" BorderBrush="#2A2A2A" BorderThickness="1" Padding="12">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <TextBlock Text="Parametres" Foreground="#E5E5E5" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,12" />

                        <GroupBox Header="Background" Margin="0,0,0,10">
                            <Grid Margin="8">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="140" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <TextBlock Grid.Row="0" Text="Mode" VerticalAlignment="Center" />
                                <TextBox x:Name="BackgroundModeBox" Grid.Row="0" Grid.Column="1" Margin="6,2" />

                                <TextBlock Grid.Row="1" Text="Stretch" VerticalAlignment="Center" />
                                <TextBox x:Name="BackgroundStretchBox" Grid.Row="1" Grid.Column="1" Margin="6,2" />

                                <TextBlock Grid.Row="2" Text="Opacity" VerticalAlignment="Center" />
                                <TextBox x:Name="BackgroundOpacityBox" Grid.Row="2" Grid.Column="1" Margin="6,2" />

                                <TextBlock Grid.Row="3" Text="ChangeInterval" VerticalAlignment="Center" />
                                <TextBox x:Name="BackgroundIntervalBox" Grid.Row="3" Grid.Column="1" Margin="6,2" />

                                <TextBlock Grid.Row="4" Text="Images (1/ligne)" VerticalAlignment="Top" />
                                <TextBox x:Name="BackgroundImagesBox" Grid.Row="4" Grid.Column="1" Margin="6,2" Height="78" AcceptsReturn="True" VerticalScrollBarVisibility="Auto" />

                                <StackPanel Grid.Row="5" Grid.Column="1" Orientation="Horizontal" Margin="6,4,6,0">
                                    <Button Content="Ajouter images..." Click="AddImages_Click" Padding="10,4" Margin="0,0,8,0" />
                                    <Button Content="Effacer" Click="ClearImages_Click" Padding="10,4" />
                                </StackPanel>

                                <TextBlock Grid.Row="6" Text="Apercu" VerticalAlignment="Top" />
                                <Border Grid.Row="6" Grid.Column="1" Height="130" Margin="6,2" BorderBrush="#555" BorderThickness="1" Background="#202020">
                                    <Grid>
                                        <Image x:Name="BackgroundPreviewImage" Stretch="UniformToFill" />
                                        <TextBlock x:Name="BackgroundPreviewFallback" Text="Aucune image" Foreground="#B0B0B0" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                    </Grid>
                                </Border>
                            </Grid>
                        </GroupBox>

                        <GroupBox Header="Matrix" Margin="0,0,0,10">
                            <Grid Margin="8">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="140" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <TextBlock Grid.Row="0" Text="GlyphColor" VerticalAlignment="Center" />
                                <TextBox x:Name="MatrixGlyphColorBox" Grid.Row="0" Grid.Column="1" Margin="6,2" />
                                <StackPanel Grid.Row="0" Grid.Column="2" Orientation="Horizontal" Margin="6,2">
                                    <Button Content="Choisir" Click="PickMatrixGlyphColor_Click" Padding="10,4" Margin="0,0,6,0" />
                                    <Border x:Name="MatrixGlyphColorPreview" Width="22" Height="22" BorderBrush="#555" BorderThickness="1" />
                                </StackPanel>

                                <TextBlock Grid.Row="1" Text="HeadColor" VerticalAlignment="Center" />
                                <TextBox x:Name="MatrixHeadColorBox" Grid.Row="1" Grid.Column="1" Margin="6,2" />
                                <StackPanel Grid.Row="1" Grid.Column="2" Orientation="Horizontal" Margin="6,2">
                                    <Button Content="Choisir" Click="PickMatrixHeadColor_Click" Padding="10,4" Margin="0,0,6,0" />
                                    <Border x:Name="MatrixHeadColorPreview" Width="22" Height="22" BorderBrush="#555" BorderThickness="1" />
                                </StackPanel>

                                <TextBlock Grid.Row="2" Text="ShadowColor" VerticalAlignment="Center" />
                                <TextBox x:Name="MatrixShadowColorBox" Grid.Row="2" Grid.Column="1" Margin="6,2" />
                                <StackPanel Grid.Row="2" Grid.Column="2" Orientation="Horizontal" Margin="6,2">
                                    <Button Content="Choisir" Click="PickMatrixShadowColor_Click" Padding="10,4" Margin="0,0,6,0" />
                                    <Border x:Name="MatrixShadowColorPreview" Width="22" Height="22" BorderBrush="#555" BorderThickness="1" />
                                </StackPanel>

                                <TextBlock Grid.Row="3" Text="FontSize" VerticalAlignment="Center" />
                                <TextBox x:Name="MatrixFontSizeBox" Grid.Row="3" Grid.Column="1" Margin="6,2" Grid.ColumnSpan="2" />

                                <TextBlock Grid.Row="4" Text="Speed" VerticalAlignment="Center" />
                                <TextBox x:Name="MatrixSpeedBox" Grid.Row="4" Grid.Column="1" Margin="6,2" Grid.ColumnSpan="2" />

                                <TextBlock Grid.Row="5" Text="Density" VerticalAlignment="Center" />
                                <TextBox x:Name="MatrixDensityBox" Grid.Row="5" Grid.Column="1" Margin="6,2" Grid.ColumnSpan="2" />

                                <TextBlock Grid.Row="6" Text="SpawnMultiplier" VerticalAlignment="Center" />
                                <TextBox x:Name="MatrixSpawnMultiplierBox" Grid.Row="6" Grid.Column="1" Margin="6,2" Grid.ColumnSpan="2" />

                                <TextBlock Grid.Row="7" Text="FadeOpacity" VerticalAlignment="Center" />
                                <TextBox x:Name="MatrixFadeOpacityBox" Grid.Row="7" Grid.Column="1" Margin="6,2" Grid.ColumnSpan="2" />

                                <TextBlock Grid.Row="8" Text="FontFamily" VerticalAlignment="Center" />
                                <TextBox x:Name="MatrixFontFamilyBox" Grid.Row="8" Grid.Column="1" Margin="6,2" Grid.ColumnSpan="2" />

                                <TextBlock Grid.Row="9" Text="Alphabet" VerticalAlignment="Center" />
                                <TextBox x:Name="MatrixAlphabetBox" Grid.Row="9" Grid.Column="1" Margin="6,2" Grid.ColumnSpan="2" />

                                <TextBlock Grid.Row="10" Text="Preset glyphes" VerticalAlignment="Top" />
                                <WrapPanel Grid.Row="10" Grid.Column="1" Grid.ColumnSpan="2" Margin="6,2">
                                    <Button Content="Katakana" Tag="Katakana" Click="ApplyAlphabetPreset_Click" Padding="8,4" Margin="0,0,6,6" />
                                    <Button Content="Hex" Tag="Hex" Click="ApplyAlphabetPreset_Click" Padding="8,4" Margin="0,0,6,6" />
                                    <Button Content="Runes" Tag="Runes" Click="ApplyAlphabetPreset_Click" Padding="8,4" Margin="0,0,6,6" />
                                    <Button Content="Demon" Tag="Demon" Click="ApplyAlphabetPreset_Click" Padding="8,4" Margin="0,0,6,6" />
                                    <Button Content="Binary" Tag="Binary" Click="ApplyAlphabetPreset_Click" Padding="8,4" Margin="0,0,6,6" />
                                </WrapPanel>

                                <TextBlock Grid.Row="11" Text="Apercu glyphes" VerticalAlignment="Top" />
                                <Border Grid.Row="11" Grid.Column="1" Grid.ColumnSpan="2" Margin="6,2" Padding="8" BorderBrush="#555" BorderThickness="1" Background="#101010">
                                    <TextBlock x:Name="MatrixGlyphPreviewText" FontFamily="Consolas" FontSize="14" Foreground="#8BFFB7" TextWrapping="Wrap" />
                                </Border>
                            </Grid>
                        </GroupBox>

                        <GroupBox Header="Effects" Margin="0,0,0,10">
                            <Grid Margin="8">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="140" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Row="0" Grid.ColumnSpan="2" Orientation="Horizontal" Margin="0,0,0,6">
                                    <CheckBox x:Name="EffectsGlowBox" Content="Glow" Margin="0,0,10,0" />
                                    <CheckBox x:Name="EffectsScanLinesBox" Content="ScanLines" Margin="0,0,10,0" />
                                    <CheckBox x:Name="EffectsCrtBox" Content="Crt" Margin="0,0,10,0" />
                                    <CheckBox x:Name="EffectsVignetteBox" Content="Vignette" Margin="0,0,10,0" />
                                    <CheckBox x:Name="EffectsSmokeBox" Content="Smoke" Margin="0,0,10,0" />
                                    <CheckBox x:Name="EffectsParticlesBox" Content="Particles" />
                                </StackPanel>

                                <TextBlock Grid.Row="1" Text="GlowIntensity" VerticalAlignment="Center" />
                                <TextBox x:Name="EffectsGlowIntensityBox" Grid.Row="1" Grid.Column="1" Margin="6,2" />

                                <TextBlock Grid.Row="2" Text="ScanLineOpacity" VerticalAlignment="Center" />
                                <TextBox x:Name="EffectsScanLineOpacityBox" Grid.Row="2" Grid.Column="1" Margin="6,2" />
                            </Grid>
                        </GroupBox>

                        <GroupBox Header="Screens" Margin="0,0,0,10">
                            <StackPanel Margin="8" Orientation="Horizontal">
                                <CheckBox x:Name="ScreensMultiScreenBox" Content="MultiScreen" Margin="0,0,10,0" />
                                <CheckBox x:Name="ScreensExitOnMoveBox" Content="ExitOnMouseMove" Margin="0,0,10,0" />
                                <CheckBox x:Name="ScreensHideCursorBox" Content="HideCursor" />
                            </StackPanel>
                        </GroupBox>

                        <GroupBox Header="Depth Layers (Profondeur)" Margin="0,0,0,10">
                            <StackPanel Margin="8">
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                    <Button x:Name="DepthAddLayerBtn" Content="Ajouter couche" Click="DepthAddLayer_Click" Padding="10,4" Margin="0,0,8,0" />
                                    <Button x:Name="DepthRemoveLayerBtn" Content="Supprimer (sel)" Click="DepthRemoveLayer_Click" Padding="10,4" IsEnabled="False" />
                                </StackPanel>

                                <ListBox x:Name="DepthLayersListBox" SelectionChanged="DepthLayersListBox_SelectionChanged" Height="280" Background="#0D0D0D" BorderBrush="#3A3A3A" Foreground="#D8D8D8">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <Border Padding="8" Background="#1A1A1A" Margin="0,2" BorderBrush="#2A2A2A" BorderThickness="1">
                                                <Grid>
                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="Auto" />
                                                        <RowDefinition Height="Auto" />
                                                        <RowDefinition Height="Auto" />
                                                        <RowDefinition Height="Auto" />
                                                    </Grid.RowDefinitions>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="80" />
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="60" />
                                                    </Grid.ColumnDefinitions>

                                                    <TextBlock Grid.Row="0" Text="Depth:" Foreground="#A0A0A0" FontSize="11" />
                                                    <Slider Grid.Row="0" Grid.Column="1" x:Name="DepthSlider" Minimum="0" Maximum="1" TickFrequency="0.1" IsSnapToTickEnabled="True" Margin="6,0,6,0" PreviewMouseLeftButtonUp="DepthLayer_Changed" />
                                                    <TextBox Grid.Row="0" Grid.Column="2" x:Name="DepthValue" Text="{Binding Depth, StringFormat=F2}" Margin="6,0" />

                                                    <TextBlock Grid.Row="1" Text="Opacity:" Foreground="#A0A0A0" FontSize="11" />
                                                    <Slider Grid.Row="1" Grid.Column="1" x:Name="OpacitySlider" Minimum="0" Maximum="1" TickFrequency="0.1" IsSnapToTickEnabled="True" Margin="6,0,6,0" PreviewMouseLeftButtonUp="DepthLayer_Changed" />
                                                    <TextBox Grid.Row="1" Grid.Column="2" x:Name="OpacityValue" Text="{Binding Opacity, StringFormat=F2}" Margin="6,0" />

                                                    <TextBlock Grid.Row="2" Text="Speed x:" Foreground="#A0A0A0" FontSize="11" />
                                                    <Slider Grid.Row="2" Grid.Column="1" x:Name="SpeedSlider" Minimum="0.1" Maximum="2.0" TickFrequency="0.1" IsSnapToTickEnabled="True" Margin="6,0,6,0" PreviewMouseLeftButtonUp="DepthLayer_Changed" />
                                                    <TextBox Grid.Row="2" Grid.Column="2" x:Name="SpeedValue" Text="{Binding SpeedMultiplier, StringFormat=F2}" Margin="6,0" />

                                                    <TextBlock Grid.Row="3" Text="Density x:" Foreground="#A0A0A0" FontSize="11" />
                                                    <Slider Grid.Row="3" Grid.Column="1" x:Name="DensitySlider" Minimum="0.1" Maximum="2.0" TickFrequency="0.1" IsSnapToTickEnabled="True" Margin="6,0,6,0" PreviewMouseLeftButtonUp="DepthLayer_Changed" />
                                                    <TextBox Grid.Row="3" Grid.Column="2" x:Name="DensityValue" Text="{Binding DensityMultiplier, StringFormat=F2}" Margin="6,0" />
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </StackPanel>
                        </GroupBox>
                    </StackPanel>
                </ScrollViewer>
            </Border>

            <TextBox x:Name="JsonBox" Grid.Column="1" FontFamily="Consolas" FontSize="14" AcceptsReturn="True" AcceptsTab="True"
                     VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto" TextWrapping="NoWrap" />
        </Grid>

        <StackPanel Grid.Row="2" Margin="0,12,0,0">
            <TextBlock Foreground="#AAA" Text="Tous les parametres sont editables via le formulaire et le JSON." />
            <TextBlock x:Name="ActivePathText" Foreground="#8FB3FF" TextWrapping="Wrap" Cursor="Hand" MouseLeftButtonUp="ActivePathText_MouseLeftButtonUp" TextDecorations="Underline" />
        </StackPanel>
    </Grid>
</Window>
