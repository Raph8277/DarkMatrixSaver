<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net10.0-windows</TargetFramework>
    <UseWPF>true</UseWPF>
    <UseWindowsForms>true</UseWindowsForms>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <AssemblyName>MatrixScreensaver</AssemblyName>
  </PropertyGroup>
  <ItemGroup>
    <ProjectReference Include="..\MatrixScreensaver.Engine\MatrixScreensaver.Engine.csproj" />
  </ItemGroup>
  <ItemGroup>
    <None Include="..\..\presets\*.json" CopyToOutputDirectory="PreserveNewest" Link="presets\%(Filename)%(Extension)" />
  </ItemGroup>
</Project>
